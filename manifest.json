{
  "manifest_version": 3,
  "name": "My Extension",
  "version": "1.0.0",
  "description": "Chrome side panel developer tool",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/test.png",
      "48": "icons/test.png",
      "128": "icons/test.png"
    }
  },
  "icons": {
    "16": "icons/test.png",
    "48": "icons/test.png",
    "128": "icons/test.png"
  }
}
